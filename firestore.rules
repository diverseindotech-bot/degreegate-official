rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email_verified == true && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          request.auth.token.email == "raajveernildz@gmail.com"
        )
        || request.auth.token.firebase.sign_in_provider == 'anonymous'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Entity Validations
    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'date', 'body', 'slug']) 
        && data.title is string && data.title.size() <= 200
        && data.date is string && data.date.size() <= 20
        && data.body is string && data.body.size() <= 50000
        && data.slug is string && data.slug.size() <= 200 && data.slug.matches('^[a-z0-9_\\-]+$')
        && (data.get('featured_image', '') is string && data.get('featured_image', '').size() <= 1000)
        && (data.get('description', '') is string && data.get('description', '').size() <= 1000)
        && (data.get('authorId', '') == request.auth.uid || data.get('authorId', '') == 'admin');
    }

    // --- Routes ---

    // Blog Posts: Public Read, Admin Write
    match /blog_posts/{postId} {
      allow read: if true; // Public access for intelligence dissemination
      
      allow create: if isAdmin() 
        && isValidId(postId)
        && isValidBlogPost(incoming())
        && incoming().keys().size() <= 8; // title, date, body, slug, featured_image, description, authorId, createdAt
        
      allow update: if isAdmin()
        && isValidBlogPost(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'date', 'body', 'slug', 'featured_image', 'description'])
        && incoming().slug == existing().slug; // Slug is immutable for URL stability
        
      allow delete: if isAdmin();
    }

    // Admins: Restricted Access
    match /admins/{adminId} {
      // Only the admin or high-level system checks can read this.
      // In a real app, you might have a super-admin.
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if false; // Managed via Firebase Console or special script
    }
  }
}
