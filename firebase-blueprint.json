{
  "entities": {
    "BlogPost": {
      "title": "Blog Post",
      "description": "An intelligence briefing or blog post.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the briefing." },
        "date": { "type": "string", "format": "date", "description": "The publication date." },
        "featured_image": { "type": "string", "description": "URL of the featured image." },
        "description": { "type": "string", "description": "A short summary of the content." },
        "body": { "type": "string", "description": "The markdown content of the post." },
        "slug": { "type": "string", "description": "URL-friendly identifier." },
        "authorId": { "type": "string", "description": "UID of the admin who published it." }
      },
      "required": ["title", "date", "body", "slug"]
    },
    "Admin": {
      "title": "Administrator",
      "description": "System administrator profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      }
    },
    "Submission": {
      "title": "Form Submission",
      "description": "Data captured from various site forms.",
      "type": "object",
      "properties": {
        "form_name": { "type": "string" },
        "data": { "type": "object" },
        "status": { "type": "string", "enum": ["unread", "read", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["form_name", "data", "status", "createdAt"]
    }
  },
  "firestore": {
    "/blog_posts/{postId}": {
      "schema": "BlogPost",
      "description": "Publicly accessible intelligence reports."
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Protected administrator records."
    },
    "/submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Form submissions for admin review."
    }
  }
}
